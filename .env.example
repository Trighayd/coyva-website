# ─────────────────────────────────────────────
# Coyva — environment variables
# Copy this to .env.local and fill in values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────

# Basiq API (get from app.basiq.io → sandbox)
BASIQ_API_KEY=your_basiq_api_key_here
BASIQ_API_URL=https://au-api.basiq.io

# NextAuth (generate secret: openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Database (Postgres — local or Supabase)
DATABASE_URL=postgresql://postgres:password@localhost:5432/coyva_dev

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
